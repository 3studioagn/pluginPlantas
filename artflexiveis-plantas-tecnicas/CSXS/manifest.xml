<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="6.0"
                   ExtensionBundleId="com.artflexiveis.plantas-tecnicas"
                   ExtensionBundleVersion="1.0.0"
                   ExtensionBundleName="3Plan"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <ExtensionList>
        <Extension Id="com.artflexiveis.plantas-tecnicas.panel" Version="1.0.0" />
    </ExtensionList>

    <ExecutionEnvironment>
        <HostList>
            <Host Name="ILST" Version="[25.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="9.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>

    <DispatchInfoList>
        <Extension Id="com.artflexiveis.plantas-tecnicas.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./client/index.html</MainPath>
                    <ScriptPath>./host/core.jsx</ScriptPath>
                    <CEFCommandLine>
                        <Parameter>--allow-file-access-from-files</Parameter>
                        <Parameter>--allow-file-access</Parameter>
                        <Parameter>--enable-nodejs</Parameter>
                        <Parameter>--mixed-context</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>3Plan</Menu>
                    <Geometry>
                        <Size>
                            <Width>363</Width>
                            <Height>620</Height>
                        </Size>
                        <MinSize>
                            <Width>320</Width>
                            <Height>520</Height>
                        </MinSize>
                        <MaxSize>
                            <Width>500</Width>
                            <Height>900</Height>
                        </MaxSize>
                    </Geometry>
                    <Icons>
                        <Icon Type="Normal">./client/assets/icons/icon-normal.png</Icon>
                        <Icon Type="RollOver">./client/assets/icons/icon-rollover.png</Icon>
                        <Icon Type="Disabled">./client/assets/icons/icon-disabled.png</Icon>
                        <Icon Type="DarkNormal">./client/assets/icons/icon-dark-normal.png</Icon>
                        <Icon Type="DarkRollOver">./client/assets/icons/icon-dark-rollover.png</Icon>
                    </Icons>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>

</ExtensionManifest>
